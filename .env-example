# Configuração de conexão com o banco de dados PostgreSQL (exemplo correspondente ao docker-compose)
DATABASE_URL="postgres://palpita:palpita_password@localhost:5432/palpita_db"

# Porta padrão de execução do servidor Next.js
PORT=3000

# Ambiente de execução (development, production, test)
NODE_ENV="development"

# ═══════════════════════════════════════════
# Segurança — JWT
# ═══════════════════════════════════════════

# Chave secreta para assinar tokens JWT (mínimo 32 caracteres)
JWT_SECRET="mude-para-uma-chave-segura-com-pelo-menos-32-caracteres"
# Tempo de expiração do token JWT (ex: 7d, 24h, 1h)
JWT_EXPIRES_IN="7d"
# Número de rounds do salt bcrypt (mínimo 10, default 12)
BCRYPT_SALT_ROUNDS=12

# ═══════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════

# Limite de tentativas de login por janela de tempo
RATE_LIMIT_LOGIN_MAX=5
# Janela de tempo para limite de login (em milissegundos, default 1 minuto)
RATE_LIMIT_LOGIN_WINDOW_MS=60000
# Limite geral de requisições por janela de tempo
RATE_LIMIT_GENERAL_MAX=100
# Janela de tempo para limite geral (em milissegundos, default 1 minuto)
RATE_LIMIT_GENERAL_WINDOW_MS=60000
